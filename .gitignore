build/
build-asan/
build-benchmarks/
build-ci/
build-coverage/
build-fuzz/
build-msan/
build-python/
build-tsan/
build-ubsan/

# ---------------------------------------------------------------------------
# CMake artefacts
# ---------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake

# ---------------------------------------------------------------------------
# Compiled objects and binaries
# ---------------------------------------------------------------------------
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out

# ---------------------------------------------------------------------------
# Python artefacts
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
.eggs/
*.whl
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Fuzz artifacts
# ---------------------------------------------------------------------------
fuzz/corpus/
fuzz/crash-*
fuzz/leak-*
fuzz/timeout-*
fuzz/oom-*

# ---------------------------------------------------------------------------
# Benchmark + test outputs
# ---------------------------------------------------------------------------
benchmark_results.txt
*.parquet
*.wal

# ---------------------------------------------------------------------------
# Editor and OS
# ---------------------------------------------------------------------------
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~
.#*

# ---------------------------------------------------------------------------
# Sanitizer profiles
# ---------------------------------------------------------------------------
*.profraw
*.profdata
default.profraw

# ---------------------------------------------------------------------------
# Doxygen output
# ---------------------------------------------------------------------------
html/
docs/doxygen/
docs/html/
docs/latex/

# ---------------------------------------------------------------------------
# Local internal workspace artifacts (never commit)
# ---------------------------------------------------------------------------
Codex_/
build-commercial-local/
CLAUDE.md
tools/signet_keygen.cpp
scripts/signet_keygen.sh
Governance_Files/
/Signet_Forge_Test
/Signet_Forge*Pre-Public*
/Signet-Forge_Launch*

