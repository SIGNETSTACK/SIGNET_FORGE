# =============================================================================
# Signet_Forge — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Build directories (CMakePresets)
# ---------------------------------------------------------------------------
build/
build-asan/
build-benchmarks/
build-ci/
build-coverage/
build-fuzz/
build-msan/
build-python/
build-tsan/
build-ubsan/

# ---------------------------------------------------------------------------
# CMake artefacts
# ---------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake

# ---------------------------------------------------------------------------
# Compiled objects and binaries
# ---------------------------------------------------------------------------
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out

# ---------------------------------------------------------------------------
# Python artefacts
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
.eggs/
*.whl
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Fuzz artifacts
# ---------------------------------------------------------------------------
fuzz/corpus/
fuzz/crash-*
fuzz/leak-*
fuzz/timeout-*
fuzz/oom-*

# ---------------------------------------------------------------------------
# Benchmark + test outputs
# ---------------------------------------------------------------------------
benchmark_results.txt
*.parquet
!wasm/sample.parquet
*.wal

# ---------------------------------------------------------------------------
# Editor and OS
# ---------------------------------------------------------------------------
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~
.#*

# ---------------------------------------------------------------------------
# Sanitizer profiles
# ---------------------------------------------------------------------------
*.profraw
*.profdata
default.profraw

# ---------------------------------------------------------------------------
# Doxygen output
# ---------------------------------------------------------------------------
html/
docs/doxygen/
docs/html/
docs/latex/

# ---------------------------------------------------------------------------
# Local workspace artifacts
# ---------------------------------------------------------------------------
build-*/
*.local

# ---------------------------------------------------------------------------
# Secrets and credentials
# ---------------------------------------------------------------------------
*.env
*.key
*.pem
*.p12
*.pfx
*.secret
*.credentials
*.jks
*.keystore

# ---------------------------------------------------------------------------
# Generated data and results
# ---------------------------------------------------------------------------
Benchmarking_Protocols/data/
Benchmarking_Protocols/results/

# ---------------------------------------------------------------------------
# clangd / LSP index cache
# ---------------------------------------------------------------------------
.cache/

# ---------------------------------------------------------------------------
# Rust build artifacts
# ---------------------------------------------------------------------------
rust/*/target/
rust/*/Cargo.lock

# Local notes and workspace files
.obsidian/
*.canvas
*.base
20[0-9][0-9]-*.md

# ---------------------------------------------------------------------------
# Internal / confidential (never commit)
# ---------------------------------------------------------------------------
CLAUDE.md
.claude/
*.env
*.secret
*.credentials
docs/internal/
docs/product-knowledge/
docs/FORUM_POSTING_GUIDE.md
docs/PENTEST_REMEDIATION_REPORT.md
docs/FORUM_POSTING_GUIDE.md
